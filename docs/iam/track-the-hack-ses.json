{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendApplicationEmailOnly",
      "Effect": "Allow",
      "Action": "ses:SendEmail",
      "Resource": [
        "arn:aws:ses:ca-central-1:847595147303:identity/hackthehill.com",
        "arn:aws:ses:ca-central-1:847595147303:configuration-set/my-first-configuration-set"
      ],
      "Condition": {
        "StringEquals": {
          "ses:FromAddress": "info@hackthehill.com"
        },
        "Bool": {
          "aws:SecureTransport": "true"
        }
      }
    }
  ]
}
